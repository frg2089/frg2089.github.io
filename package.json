{
  "name": "shimakaze-blog",
  "version": "2.0.0",
  "type": "module",
  "description": "岛风的博客",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "scripts": {
    "build": "vitepress build",
    "dev": "vitepress dev",
    "format": "prettier --write .",
    "prepare": "husky",
    "preview": "vitepress preview"
  },
  "devDependencies": {
    "@giscus/vue": "^3.1.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "latest",
    "algoliasearch": "^5.49.2",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "holiday-calendar": "latest",
    "htmlparser2": "^10.1.0",
    "husky": "^9.1.7",
    "iso-3166-1": "^2.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-pkg": "^0.21.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitepress": "1.6.4",
    "vitepress-plugin-legend": "^1.3.0",
    "vitepress-theme-teek": "^1.5.5",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "semi": false,
